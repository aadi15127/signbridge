{
  "name": "signbridge",
  "version": "1.0.0",
  "description": "Real-Time Sign Language Translator — MediaPipe Hands + FaceMesh with micro-gesture and emotional context detection",
  "main": "index.html",
  "scripts": {
    "start": "npx serve . --port 3000",
    "dev": "npx live-server --port=3000 --open=index.html",
    "lint": "npx eslint src/**/*.js",
    "format": "npx prettier --write src/**/*.js styles/**/*.css",
    "build": "npx parcel build index.html --out-dir dist --public-url ./",
    "test": "npx jest --coverage"
  },
  "keywords": [
    "sign-language",
    "ASL",
    "mediapipe",
    "computer-vision",
    "accessibility",
    "real-time",
    "tensorflow",
    "hand-tracking",
    "emotion-detection",
    "face-mesh",
    "webrtc",
    "gesture-recognition"
  ],
  "author": "SignBridge Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/signbridge.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/signbridge/issues"
  },
  "homepage": "https://your-username.github.io/signbridge",
  "dependencies": {},
  "devDependencies": {
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "live-server": "^1.2.2",
    "serve": "^14.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Edge versions"
  ],
  "engines": {
    "node": ">=16.0.0"
  }
}
